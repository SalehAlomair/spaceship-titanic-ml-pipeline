    "import pandas as pd\n",
    "import numpy as np\n",
    "from sklearn.model_selection import train_test_split, GridSearchCV, GroupShuffleSplit, GroupKFold\n",
    "from sklearn.metrics import accuracy_score, roc_auc_score\n",
    "from sklearn.preprocessing import StandardScaler, FunctionTransformer\n",
    "from sklearn.compose import ColumnTransformer\n",
    "from sklearn.pipeline import Pipeline\n",
    "from sklearn.ensemble import VotingClassifier, RandomForestClassifier\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "from catboost import CatBoostClassifier\n",
    "from xgboost import XGBClassifier\n",
    "import lightgbm as lgb\n",
    "\n",
    "def evaluate_models_optimized(models, X, y, param_grids=None, groups=None, test_size=0.2, random_state=42, stratify=True):\n",
    "    '''\n",
    "    models: dict => {'model_name': model_instance, ...}\n",
    "    X: features DataFrame\n",
    "    y: target features\n",
    "    param_grids: dict containing hyperparameter grids, keys must match model names.\n",
    "                 Parameters should be prefixed with 'classifier__' because of the Pipeline.\n",
    "    groups: optional group labels for group-aware split/CV.\n",
    "    '''\n",
    "\n",
    "    if groups is not None:\n",
    "        groups = groups.loc[X.index]\n",
    "        gss = GroupShuffleSplit(n_splits=1, test_size=test_size, random_state=random_state)\n",
    "        tr_idx, val_idx = next(gss.split(X, y, groups=groups))\n",
    "        X_tr, X_val = X.iloc[tr_idx], X.iloc[val_idx]\n",
    "        y_tr, y_val = y.iloc[tr_idx], y.iloc[val_idx]\n",
    "        groups_tr = groups.iloc[tr_idx]\n",
    "    else:\n",
    "        stratify_param = y if stratify else None\n",
    "        X_tr, X_val, y_tr, y_val = train_test_split(\n",
    "            X, y, test_size=test_size, random_state=random_state, stratify=stratify_param\n",
    "        )\n",
    "        groups_tr = None\n",
    "\n",
    "    # 1. Define feature groupings for transformation\n",
    "    log_features = ['RoomService', 'FoodCourt', 'ShoppingMall', 'Spa', 'VRDeck', 'TotalSpends']\n",
    "    other_num_features = ['GroupMember', 'GroupSize', 'Age', 'CabinNum']\n",
    "\n",
    "    # Ensure columns exist in the dataset to avoid errors\n",
    "    log_features = [f for f in log_features if f in X.columns]\n",
    "    other_num_features = [f for f in other_num_features if f in X.columns]\n",
    "\n",
    "    # 2. Create Data Transformers\n",
    "    # Pipeline for financial data: Log transform (np.log1p handles zeros safely) then Scale\n",
    "    log_transformer = Pipeline(steps=[\n",
    "        ('log', FunctionTransformer(np.log1p, validate=False)),\n",
    "        ('scaler', StandardScaler())\n",
    "    ])\n",
    "\n",
    "    preprocessor = ColumnTransformer(transformers=[\n",
    "        ('log_num', log_transformer, log_features),\n",
    "        ('other_num', StandardScaler(), other_num_features)\n",
    "    ], remainder='passthrough')\n",
    "\n",
    "    results = []\n",
    "    best_estimators = {}\n",
    "\n",
    "    # 3. Train Individual Models\n",
    "    for name, model in models.items():\n",
    "        if name == 'Ensemble':\n",
    "            continue # Skip Ensemble for now, we will build it dynamically later\n",
    "\n",
    "        print(f'Training {name}...')\n",
    "\n",
    "        # Chain preprocessing and the classifier into a single Pipeline to prevent data leakage\n",
    "        pipeline = Pipeline(steps=[\n",
    "            ('preprocessor', preprocessor),\n",
    "            ('classifier', model)\n",
    "        ])\n",
    "\n",
    "        if param_grids and name in param_grids:\n",
    "            # Use group-aware CV when groups are provided\n",
    "            cv_strategy = GroupKFold(n_splits=5) if groups_tr is not None else 5\n",
    "            grid = GridSearchCV(pipeline, param_grids[name], cv=cv_strategy, scoring='accuracy', n_jobs=-1)\n",
    "            if groups_tr is not None:\n",
    "                grid.fit(X_tr, y_tr, groups=groups_tr)\n",
    "            else:\n",
    "                grid.fit(X_tr, y_tr)\n",
    "            best_model = grid.best_estimator_\n",
    "            print(f'Best params for {name}: {grid.best_params_}')\n",
    "        else:\n",
    "            best_model = pipeline\n",
    "            best_model.fit(X_tr, y_tr)\n",
    "\n",
    "        # Save the optimized model to use in the Ensemble later\n",
    "        best_estimators[name] = best_model\n",
    "\n",
    "        # Evaluation\n",
    "        y_pred = best_model.predict(X_val)\n",
    "        y_proba = best_model.predict_proba(X_val)[:,1] if hasattr(best_model, \"predict_proba\") else y_pred\n",
    "\n",
    "        acc = accuracy_score(y_val, y_pred)\n",
    "        auc = roc_auc_score(y_val, y_proba)\n",
    "\n",
    "        results.append({'Model': name, 'Accuracy': acc, 'ROC_AUC': auc})\n",
    "        print(f'{name} done: Accuracy= {acc:.4f}, ROC_AUC= {auc:.4f}\\n')\n",
    "\n",
    "    # 4. Build the Ensemble using the Optimized Models\n",
    "    if best_estimators and 'Ensemble' in models:\n",
    "        print('Training Optimized Ensemble...')\n",
    "\n",
    "        optimized_estimators = [\n",
    "            ('LightGBM', best_estimators['LightGBM'].named_steps['classifier']),\n",
    "            ('CatBoost', best_estimators['CatBoost'].named_steps['classifier']),\n",
    "            ('XGBoost', best_estimators['XGBoost'].named_steps['classifier'])\n",
    "        ]\n",
    "\n",
    "        ensemble_classifier = VotingClassifier(\n",
    "            estimators=optimized_estimators,\n",
    "            voting='soft',\n",
    "            weights=[3, 2, 1]\n",
    "        )\n",
    "\n",
    "        # Create a final Pipeline for the Ensemble to ensure data preprocessing is applied\n",
    "        ensemble_pipeline = Pipeline(steps=[\n",
    "            ('preprocessor', preprocessor),\n",
    "            ('classifier', ensemble_classifier)\n",
    "        ])\n",
    "\n",
    "        ensemble_pipeline.fit(X_tr, y_tr)\n",
    "\n",
    "        y_pred = ensemble_pipeline.predict(X_val)\n",
    "        y_proba = ensemble_pipeline.predict_proba(X_val)[:,1]\n",
    "\n",
    "        acc = accuracy_score(y_val, y_pred)\n",
    "        auc = roc_auc_score(y_val, y_proba)\n",
    "\n",
    "        results.append({'Model': 'Top3_Ensemble', 'Accuracy': acc, 'ROC_AUC': auc})\n",
    "        print(f'Top3_Ensemble done: Accuracy= {acc:.4f}, ROC_AUC= {auc:.4f}\\n')\n",
    "\n",
    "    return pd.DataFrame(results).sort_values(by='Accuracy', ascending=False)"
   ]
